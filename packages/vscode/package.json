{
  "name": "xolito-vscode",
  "displayName": "Xolito 🦎",
  "description": "Tu ajolote regañón para VS Code. Detecta errores, te regaña con cariño y habla español mexicano.",
  "version": "0.3.1",
  "publisher": "xolito",
  "icon": "assets/xolito_idle.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/JonatanJHL/pet_mexican"
  },
  "homepage": "https://github.com/JonatanJHL/pet_mexican#readme",
  "bugs": {
    "url": "https://github.com/JonatanJHL/pet_mexican/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "pet",
    "mascota",
    "ajolote",
    "mexicano",
    "fun",
    "companion",
    "xolito",
    "boss mode",
    "panic"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "xolito.show",
        "title": "🦎 Mostrar Xolito"
      },
      {
        "command": "xolito.greet",
        "title": "🦎 Xolito: ¡Hola!"
      },
      {
        "command": "xolito.toggle",
        "title": "🦎 Xolito: Toggle comentarios inline"
      },
      {
        "command": "xolito.panicButton",
        "title": "🦎 Xolito: ¡Ahí viene el patrón! (Boss Mode)"
      }
    ],
    "keybindings": [
      {
        "command": "xolito.panicButton",
        "key": "shift+escape",
        "when": "editorFocus"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "package": "node build.mjs && vsce package --no-dependencies",
    "publish": "node build.mjs && vsce publish --no-dependencies"
  },
  "dependencies": {
    "@xolito/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  },
  "readme": "MARKETPLACE.md"
}